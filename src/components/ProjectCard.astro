---
interface Props {
  name: string;
  description: string;
  status: "WIP" | "Live" | "Dead";
  tags?: string[];
  href?: string;
  focused?: boolean;
}

const { name, description, status, tags = [], href, focused = false } = Astro.props;

const statusColors = {
  WIP: "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400",
  Live: "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400",
  Dead: "bg-neutral-100 text-neutral-500 dark:bg-neutral-800 dark:text-neutral-500",
};

const Tag = href ? "a" : "div";
---

<div class="relative">
  {focused && (
    <span class="absolute -top-px left-4 -translate-y-1/2 text-xs px-1 font-medium text-indigo-500 dark:text-indigo-400 bg-[#faf6ef] dark:bg-[#141c26] z-10">
      Current focus
    </span>
  )}
  <Tag
    href={href}
    target={href ? "_blank" : undefined}
    rel={href ? "noopener noreferrer" : undefined}
    class:list={[
      "block rounded-xl p-5 transition-colors",
      focused
        ? "border border-indigo-400 dark:border-indigo-500"
        : "border border-neutral-200 dark:border-neutral-800",
      href && "hover:border-indigo-500 dark:hover:border-indigo-400 cursor-pointer",
      !focused && href && "hover:border-neutral-300 dark:hover:border-neutral-700",
    ]}
  >
  <div class="flex items-start justify-between gap-3 mb-2">
    <h3 class="font-semibold">{name}</h3>
    <div class="flex items-center gap-1.5">
      <span class:list={["inline-flex items-center gap-1.5 text-xs px-2 py-1 rounded-full font-medium whitespace-nowrap", statusColors[status]]}>
        <span>{{ WIP: "🚧", Live: "🔴", Dead: "🪦" }[status]}</span><span>{status}</span>
      </span>
    </div>
  </div>
  <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-3">
    {description}
  </p>
  {
    tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="text-xs px-2 py-0.5 rounded bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400">
            {tag}
          </span>
        ))}
      </div>
    )
  }
  </Tag>
</div>
