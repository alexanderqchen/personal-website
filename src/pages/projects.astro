---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import projects from "../data/projects.json";
---

<BaseLayout title="Projects — Alexander Chen" description="Things I've built and am building.">
  <h1 class="text-3xl font-bold mb-2 font-serif">Projects</h1>
  <p class="text-neutral-600 dark:text-neutral-400 mb-10">
    Things I've built and am building.
  </p>

  <div class="grid gap-4">
    {projects.map(p => (
      <ProjectCard
        name={p.name}
        description={p.description}
        status={p.status}
        href={p.href}
        focused={p.focused}
      />
    ))}
  </div>
</BaseLayout>
