---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
---

<BaseLayout title="Projects — Alexander Chen" description="Things I've built and am building.">
  <h1 class="text-3xl font-bold mb-2 font-serif">Projects</h1>
  <p class="text-neutral-600 dark:text-neutral-400 mb-10">
    Things I've built and am building.
  </p>

  <div class="grid gap-4">
    <ProjectCard
      name="orb-ui"
      description="Open-source React component library for voice AI agents."
      status="WIP"
      href="https://github.com/alexanderqchen/orb-ui"
      focused
    />
    <ProjectCard
      name="TypeChinese"
      description="Typing practice for Chinese learners. Still getting 500 users a month."
      status="Live"
      href="https://typechinese.io"
      focused
    />
    <ProjectCard
      name="Keyboard Layout Tester"
      description="Test and compare keyboard layouts side by side."
      status="Live"
      href="https://keyboard.experimental.software"
    />
    <ProjectCard
      name="Google Flights Currency"
      description="See Google Flights prices in your local currency."
      status="Live"
      href="https://chromewebstore.google.com/detail/google-flights-currency-s/nameliafoadmpledepdbcgnogcnfiemo?hl=en"
    />
    <ProjectCard
      name="1000 Pound Club"
      description="Become a member of the 1000 pound club."
      status="Dead"
      href="https://1000pound.com"
    />
    <ProjectCard
      name="flux.rip"
      description="A social media site where the UX is so weird it becomes unusable. Built in college."
      status="Dead"
      href="https://github.com/UCLA-Creative-Labs/flux"
    />
  </div>
</BaseLayout>
