---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Alexander Chen`} description={post.data.description}>
  <article>
    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-2 font-serif">{post.data.title}</h1>
      <time class="text-sm text-neutral-500">
        {post.data.date.toLocaleDateString("en-US", {
          month: "long",
          day: "numeric",
          year: "numeric",
        })}
      </time>
    </header>
    <div class="prose prose-neutral dark:prose-invert max-w-none">
      <Content />
    </div>
  </article>
  <div class="mt-12">
    <a href="/blog" class="text-sm text-accent hover:text-accent-dark transition-colors">
      &larr; All posts
    </a>
  </div>
</BaseLayout>
