---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import GitHubActivity from "../components/GitHubCalendar.tsx";
import StatusBubble from "../components/StatusBubble.astro";
import BlogPostCard from "../components/BlogPostCard.astro";
import status from "../data/status.json";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Alexander Chen">
  <style>
    .trail-dot { background: #e7e5e4; }
    :global(.dark) .trail-dot { background: #2a2a2a; }
  </style>

  <!-- Status + Intro -->
  <section class="mb-16">
    <div class="flex justify-center mb-16 px-5 sm:px-0 relative z-10">
      <StatusBubble emoji={status.emoji} text={status.text} />
    </div>
    <div>
      <h1 class="text-3xl font-bold mb-4 font-serif">Hey, I'm <span class="relative inline-block"><!--
        --><span class="absolute" style="bottom: calc(100% + 4px); left: calc(100% - 14px); width: 44px; height: 22px; pointer-events: none;"><span class="trail-dot block rounded-full absolute" style="width:6px;height:6px;left:0px;bottom:0;"></span><span class="trail-dot block rounded-full absolute" style="width:10px;height:10px;left:14px;bottom:7px;"></span><span class="trail-dot block rounded-full absolute" style="width:14px;height:14px;left:28px;bottom:14px;"></span></span><!--
        -->Alex!</span></h1>
      <div class="flex items-center gap-3 mb-4">
        <a href="https://x.com/alexqchen" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 transition-colors" aria-label="Twitter">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://github.com/alexanderqchen" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 transition-colors" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        </a>
        <a href="https://linkedin.com/in/alexanderqchen" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 transition-colors" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
      <p class="text-lg text-neutral-600 dark:text-neutral-400 leading-relaxed">
        I build things. Still figuring out what I want that to mean.
      </p>
      <p class="text-lg text-neutral-600 dark:text-neutral-400 leading-relaxed mt-3">
        YC W25 alum — cofounded a startup, learned a lot, moved on. Before that: a year building and shipping things in Taiwan, then startups backed by Sequoia, a16z, Google Ventures, including one IPO. Amazon. UCLA CS.
      </p>
    </div>
  </section>

  <!-- Currently focused on -->
  <section class="mb-16">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 mb-4">
      Currently focused on
    </h2>
    <div class="grid gap-4 sm:grid-cols-2">
      <ProjectCard
        name="orb-ui"
        description="Open-source React component library for voice AI agents."
        status="WIP"
        href="https://github.com/alexanderqchen/orb-ui"
      />
      <ProjectCard
        name="TypeChinese"
        description="Typing practice for Chinese learners. Still getting 500 users a month."
        status="Live"
        href="https://typechinese.io"
      />
    </div>
    <a
      href="/projects"
      class="inline-block mt-4 text-sm text-accent hover:text-accent-dark transition-colors"
    >
      All projects &rarr;
    </a>
  </section>

  <!-- Recent Writing -->
  <section class="mb-16">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 mb-4">
      Recent Writing
    </h2>
    <div class="space-y-4">
      {
        posts.map((post) => (
          <BlogPostCard
            id={post.id}
            title={post.data.title}
            body={post.body}
            date={post.data.date}
          />
        ))
      }
    </div>
    <a
      href="/blog"
      class="inline-block mt-4 text-sm text-accent hover:text-accent-dark transition-colors"
    >
      All posts &rarr;
    </a>
  </section>

  <!-- GitHub Activity -->
  <section class="mb-16">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 mb-4">
      GitHub
    </h2>
    <div
      class="border border-neutral-200 dark:border-neutral-800 rounded-xl p-5"
    >
      <GitHubActivity client:load />
    </div>
  </section>
</BaseLayout>
