---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import GitHubActivity from "../components/GitHubCalendar.tsx";
import StatusBubble from "../components/StatusBubble.astro";
import status from "../data/status.json";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Alexander Chen">
  <!-- Status + Intro -->
  <section class="mb-16">
    <div class="ml-48">
      <StatusBubble emoji={status.emoji} text={status.text} />
    </div>
    <div>
      <h1 class="text-3xl font-bold mb-4 font-serif">Hey, I'm Alex!</h1>
      <p class="text-lg text-neutral-600 dark:text-neutral-400 leading-relaxed">
        I build things. Still figuring out what I want that to mean.
      </p>
      <p class="text-lg text-neutral-600 dark:text-neutral-400 leading-relaxed mt-3">
        YC W25 alum — cofounded a startup, learned a lot, moved on. Before that: a year building and shipping things in Taiwan, then startups backed by Sequoia, a16z, Google Ventures, including one IPO. Amazon. UCLA CS.
      </p>
    </div>
  </section>

  <!-- Currently focused on -->
  <section class="mb-16">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 mb-4">
      Currently focused on
    </h2>
    <div class="grid gap-4 sm:grid-cols-2">
      <ProjectCard
        name="orb-ui"
        description="Open-source React component library for voice AI agents."
        status="WIP"
        href="https://github.com/alexanderqchen/orb-ui"
      />
      <ProjectCard
        name="TypeChinese"
        description="Typing practice for Chinese learners. Still getting 500 users a month."
        status="Live"
        href="https://typechinese.io"
      />
    </div>
    <a
      href="/projects"
      class="inline-block mt-4 text-sm text-accent hover:text-accent-dark transition-colors"
    >
      All projects &rarr;
    </a>
  </section>

  <!-- GitHub Activity -->
  <section class="mb-16">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 mb-4">
      GitHub
    </h2>
    <div
      class="border border-neutral-200 dark:border-neutral-800 rounded-xl p-5"
    >
      <GitHubActivity client:load />
    </div>
  </section>

  <!-- Revenue -->
  <!-- Recent Writing -->
  <section class="mb-16">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 mb-4">
      Recent Writing
    </h2>
    <div class="space-y-4">
      {
        posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="block border border-neutral-200 dark:border-neutral-800 rounded-xl p-5 hover:border-neutral-300 dark:hover:border-neutral-700 transition-colors"
          >
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="font-medium">{post.data.title}</h3>
              <time class="text-sm text-neutral-500 whitespace-nowrap">
                {post.data.date.toLocaleDateString("en-US", {
                  month: "short",
                  day: "numeric",
                  year: "numeric",
                })}
              </time>
            </div>
            <p class="text-sm text-neutral-600 dark:text-neutral-400 mt-1">
              {post.data.description}
            </p>
          </a>
        ))
      }
    </div>
    <a
      href="/blog"
      class="inline-block mt-4 text-sm text-accent hover:text-accent-dark transition-colors"
    >
      All posts &rarr;
    </a>
  </section>
</BaseLayout>
