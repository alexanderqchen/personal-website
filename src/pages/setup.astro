---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Setup — Alexander Chen" description="What I use to build things.">
  <h1 class="text-3xl font-bold mb-2 font-serif">Setup</h1>
  <p class="text-neutral-600 dark:text-neutral-400 mb-10">
    What I use to build things.
  </p>

  <section class="mb-10">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 mb-4">
      Hardware
    </h2>
    <ul class="space-y-3">
      <li class="flex items-baseline gap-3">
        <span class="font-medium">MacBook Pro 16"</span>
        <span class="text-sm text-neutral-500">2019, Intel i9</span>
      </li>
    </ul>
  </section>

  <section class="mb-10">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 mb-4">
      Software
    </h2>
    <ul class="space-y-3">
      <li class="flex items-baseline gap-3">
        <span class="font-medium">VS Code</span>
        <span class="text-sm text-neutral-500">Editor</span>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="font-medium">iTerm2</span>
        <span class="text-sm text-neutral-500">Terminal</span>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="font-medium">Figma</span>
        <span class="text-sm text-neutral-500">Design</span>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="font-medium">Arc</span>
        <span class="text-sm text-neutral-500">Browser</span>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="font-medium">Notion</span>
        <span class="text-sm text-neutral-500">Notes & planning</span>
      </li>
    </ul>
  </section>

  <p class="text-sm text-neutral-500 italic">
    This page is a work in progress. Will add more as I go.
  </p>
</BaseLayout>
