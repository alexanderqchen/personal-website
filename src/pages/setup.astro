---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Setup — Alexander Chen" description="What I use to build things.">
  <h1 class="text-3xl font-bold mb-2 font-serif">Setup</h1>
  <p class="text-neutral-600 dark:text-neutral-400 mb-10">
    What I use to build things.
  </p>

  <section class="mb-10">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 mb-4">
      My Setup
    </h2>
    <ul class="space-y-3">
      <li class="flex items-baseline gap-3">
        <span class="font-medium">M4 MacBook Air 13"</span>
        <span class="text-sm text-neutral-500">Primary machine</span>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="font-medium">Rainy 75</span>
        <span class="text-sm text-neutral-500">Keyboard</span>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="font-medium">Logitech G Pro</span>
        <span class="text-sm text-neutral-500">Mouse</span>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="font-medium">Dell 4K monitor</span>
        <span class="text-sm text-neutral-500">External display (model unknown)</span>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="font-medium">Apple AirPods Max</span>
        <span class="text-sm text-neutral-500">Headphones</span>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="font-medium">iPhone 17 Pro Max</span>
        <span class="text-sm text-neutral-500">Phone</span>
      </li>
    </ul>
  </section>

  <section class="mb-10">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500 mb-4">
      ClawdBot's Setup
    </h2>
    <p class="text-sm text-neutral-500 mb-4">
      My AI assistant runs on some hand-me-down hardware:
    </p>
    <ul class="space-y-3">
      <li class="flex items-baseline gap-3">
        <span class="font-medium">MacBook Pro 16" i9</span>
        <span class="text-sm text-neutral-500">2020, runs headless with lid closed</span>
      </li>
    </ul>
  </section>

  <p class="text-sm text-neutral-500 italic">
    This page is a work in progress. Will add more as I go.
  </p>
</BaseLayout>
